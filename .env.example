NEXT_PUBLIC_VIGISWAP_SITE_URL=https://vigiswap.com
NEXT_PUBLIC_VIGISWAP_BRAND=VigiSwap

# Connect this to the existing VestigeIndex backend/API.
# Use WWW: apex 301-redirects to www and a 301 on POST can drop the body.
VESTIGE_API_BASE=https://www.vestigeindex.com/api
# Optional. VestigeIndex's Cloudflare Functions already hold the upstream keys
# (LI.FI/1inch/etc.) server-side, so this is usually left blank.
VESTIGE_API_KEY=

# VIGIX native platform token.
NEXT_PUBLIC_VIGIX_CHAIN_ID=137
NEXT_PUBLIC_VIGIX_CONTRACT_ADDRESS=0xea1989dDc9F7db000347F6Ac14C63fd395B6EDAd
NEXT_PUBLIC_VIGIX_SYMBOL=VIGIX

# WalletConnect/Reown only if VestigeIndex already uses it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
